{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "types": []
  },
  "include": [
    "src/**/*.ts"
  ],
  "extends": "expo/tsconfig.base"
}
