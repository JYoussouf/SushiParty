# Environment is selected automatically by Expo based on how you run the app:
#   expo start          → .env.development  (local Wrangler dev server)
#   eas build / export  → .env.production   (deployed Cloudflare Worker)
#
# Copy the relevant file and fill in your values — do not edit this file directly.

# .env.development
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# .env.production
# EXPO_PUBLIC_API_BASE_URL=https://sushi-party-api.joseppy-workers.workers.dev

# Ads (AdMob) — interstitial after a party is submitted. OFF by default.
# EXPO_PUBLIC_ADS_ENABLED=false
# Real interstitial ad unit IDs (from your AdMob account). When unset, Google test ads are used.
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_ANDROID=ca-app-pub-XXXXX/XXXXX
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_IOS=ca-app-pub-XXXXX/XXXXX
