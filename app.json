{
  "expo": {
    "name": "Sushi Party",
    "slug": "sushi-party",
    "owner": "joseppy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/sushi-party.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "sushiparty",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.joseppy.sushiparty",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/sushi-party.png",
        "backgroundColor": "#0E1A3D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.joseppy.sushiparty"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sushi Party uses your location to find sushi spots near you.",
          "locationAlwaysAndWhenInUsePermission": "Allow Sushi Party to use your location to find nearby restaurants."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Sushi Party uses your camera to scan group QR codes."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "./plugins/withKotlinSkipMetadataCheck"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "4dd74eba-2b10-4a65-8003-ea12b7bad396"
      }
    }
  }
}
